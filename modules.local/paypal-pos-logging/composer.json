{
    "name": "inpsyde/paypal-pos-logging",
    "type": "inpsyde-module",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "dhii/module-interface": "^0.2 || ^0.3",
        "psr/log": "^1.1",
        "ext-json": "*"
    },
    "require-dev": {
        "brianium/paratest": "^4.0 || ^6.0",
        "mockery/mockery": "^1.0",
        "phpunit/phpunit": "^8.0 || ^9.0"
    },
    "autoload": {
        "psr-4": {
            "Syde\\PayPal\\PointOfSale\\Logging\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Syde\\PayPal\\PointOfSale\\Logging\\Tests\\": "tests/PHPUnit"
        },
        "files": [
            "tests/PHPUnit/Stub/WC_Logger_Interface.php"
        ]
    }
}
