{
    "name": "inpsyde/inpsyde-debug",
    "type": "inpsyde-module",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^7.4 | ^8.0",
        "inpsyde/modularity": "^1.7",
        "psr/log": "^1.1",
        "ext-json": "*"
    },
    "require-dev": {
        "brianium/paratest": "^4.0 || ^6.0",
        "mockery/mockery": "^1.0",
        "phpunit/phpunit": "^8.0 || ^9.0"
    },
    "autoload": {
        "psr-4": {
            "Inpsyde\\Debug\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Inpsyde\\Debug\\Tests\\": "tests/PHPUnit"
        }
    }
}
