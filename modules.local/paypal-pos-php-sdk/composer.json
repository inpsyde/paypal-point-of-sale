{
    "name": "inpsyde/paypal-pos-php-sdk",
    "type": "inpsyde-module",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "../../packages.local/wc-product-contracts"
        }
    ],
    "require": {
        "inpsyde/modularity": "^1.7",
        "werkspot/enum": "^2.1",
        "psr/log": "^1.1",
        "inpsyde/wc-product-contracts": "*",
        "symfony/uid": "^5.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^8.0 || ^9.0",
        "inpsyde/monkery-test-case": "^6.0.1",
        "symfony/var-dumper": "^5.0",
        "vlucas/phpdotenv": "^4.1",
        "fzaninotto/faker": "^1.9",
        "brianium/paratest": "^4.0 || ^6.0"
    },
    "autoload": {
        "psr-4": {
            "Syde\\PayPal\\PointOfSale\\PhpSdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Syde\\PayPal\\PointOfSale\\PhpSdk\\Tests\\": "tests/PHPUnit/Helper"
        }
    }
}
