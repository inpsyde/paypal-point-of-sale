{
    "name": "zettle-woocommerce",
    "version": "0.1.0",
    "description": "PayPal Point of Sale for WooCommerce",
    "repository": "https://github.com/inpsyde/PayPal-Zettle-POS",
    "license": "GPL-2.0",
    "author": "Inpsyde GmbH",
    "scripts": {
        "install:assets": "cd modules/paypal-pos-assets && npm ci",
        "install:products-assets": "cd modules/paypal-pos-product-settings && npm ci",
        "install:product-debug-assets": "cd modules/paypal-pos-product-debug && npm ci",
        "postinstall": "[ \"$CI\" = \"true\" ] || run-s install:*",
        "build:assets": "cd modules/paypal-pos-assets && yarn run build",
        "build:products-assets": "cd modules/paypal-pos-product-settings && yarn run build",
        "build:product-debug-assets": "cd modules/paypal-pos-product-debug && yarn run build",
        "build": "[ \"$CI\" = \"true\" ] || run-p build:*",
        "watch:assets": "cd modules/paypal-pos-assets && yarn run watch",
        "watch:products-assets": "cd modules/paypal-pos-product-settings && yarn run watch",
        "watch": "run-p watch:*",
        "e2e:test": "playwright test",
        "e2e:smoke": "playwright test --grep 'smoke'",
        "e2e:critical": "playwright test --grep 'critical'",
        "e2e:regression": "playwright test --grep 'regression'",
        "e2e:test:ci": "playwright test",
        "e2e:smoke:ci": "playwright test --grep 'smoke'",
        "e2e:critical:ci": "playwright test --grep 'critical'",
        "e2e:regression:ci": "playwright test --grep 'regression'",
        "e2e:build-zip": "composer install --no-dev --prefer-dist && DIST=$(mktemp -d) && mkdir -p $DIST/paypal-point-of-sale && rsync -aL --exclude-from=.distignore --exclude '.env*' --exclude '.wp-env*' --exclude playwright.config.ts --exclude tsconfig.json --exclude storage-states . $DIST/paypal-point-of-sale/ && (cd $DIST && zip -r paypal-point-of-sale.zip paypal-point-of-sale/) && mkdir -p tests/qa/resources/files && cp $DIST/paypal-point-of-sale.zip tests/qa/resources/files/",
        "e2e:setup": "npm run e2e:build-zip && npx wp-env run cli wp plugin install /var/www/html/plugin-source/tests/qa/resources/files/paypal-point-of-sale.zip && npx wp-env run cli wp rewrite structure '/%postname%/' --hard && npx wp-env run cli wp plugin activate woocommerce",
        "e2e:lint": "tsc --noEmit"
    },
    "dependencies": {
        "npm-run-all": "^4.1.5"
    },
    "devDependencies": {
        "@inpsyde/playwright-utils": "^5.1.0",
        "@playwright/test": "^1.60.0",
        "@types/node": "^25.9.1",
        "@wordpress/env": "^11.8.0",
        "dotenv": "^16.0.0",
        "patch-package": "^8.0.1",
        "typescript": "^5.5.0"
    },
    "overrides": {
        "@inpsyde/playwright-utils": {
            "@playwright/test": "$@playwright/test",
            "playwright": "$@playwright/test",
            "playwright-core": "$@playwright/test"
        }
    }
}
