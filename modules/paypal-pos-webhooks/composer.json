{
    "name": "inpsyde\/paypal-pos-webhooks",
    "type": "inpsyde-module",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "..\/..\/packages.local\/wc-product-contracts"
        },
        {
            "type": "path",
            "url": "..\/inpsyde-queue"
        },
        {
            "type": "path",
            "url": "..\/paypal-pos-php-sdk"
        }
    ],
    "require": {
        "dhii\/module-interface": "^0.2 || ^0.3",
        "inpsyde\/inpsyde-queue": "*",
        "inpsyde\/paypal-pos-php-sdk": "*"
    },
    "require-dev": {
        "phpunit\/phpunit": "^8.0 || ^9.0",
        "inpsyde\/monkery-test-case": "^6.0.1",
        "brianium\/paratest": "^4.0 || ^6.0",
        "nyholm\/psr7": "^1.2"
    },
    "autoload": {
        "psr-4": {
            "Syde\\Vendor\\Zettle\\Syde\\PayPal\\PointOfSale\\Webhooks\\": "src\/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Syde\\Vendor\\Zettle\\Syde\\PayPal\\PointOfSale\\Webhooks\\Test\\": "tests\/PHPUnit\/Helper"
        }
    }
}