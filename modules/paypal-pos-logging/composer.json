{
    "name": "inpsyde\/paypal-pos-logging",
    "type": "inpsyde-module",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "inpsyde\/modularity": "^1.7",
        "psr\/log": "^1.1",
        "ext-json": "*"
    },
    "require-dev": {
        "brianium\/paratest": "^4.0 || ^6.0",
        "mockery\/mockery": "^1.0",
        "phpunit\/phpunit": "^8.0 || ^9.0",
        "brain\/monkey": "2.*"
    },
    "autoload": {
        "psr-4": {
            "Syde\\Vendor\\Zettle\\Syde\\PayPal\\PointOfSale\\Logging\\": "src\/"
        }
