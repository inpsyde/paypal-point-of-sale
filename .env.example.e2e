# Copy this file to .env and fill in real values for local development
# Never commit .env — it is gitignored

# Site (wp-env default)
WP_BASE_URL=http://127.0.0.1:8100
WP_USERNAME=admin
WP_PASSWORD=password

# Storage states
STORAGE_STATE_PATH=./storage-states
STORAGE_STATE_PATH_ADMIN=./storage-states/admin.json

# CLI — wp-env for local development
WPCLI_ENV_TYPE=wpenv

# PayPal POS sandbox API key
PAYPAL_POS_API_KEY=

# WooCommerce REST API (optional — used by wooCommerceApi fixture)
WC_API_KEY=
WC_API_SECRET=

# ── Remote / Kinsta — set WPCLI_ENV_TYPE=ssh to target a remote host ─────────
# WPCLI_ENV_TYPE=ssh
# SSH_LOGIN=username
# SSH_HOST=ssh.kinsta.cloud
# SSH_PORT=12345
# SSH_PATH=/www/paypal-pos.paypal.wpcust.cloud/public

# HTTP basic auth — Kinsta staging enables this by default
# WP_BASIC_AUTH_USER=
# WP_BASIC_AUTH_PASS=
# IGNORE_HTTPS_ERRORS=false