{
    "name": "dhii\/containers",
    "description": "A selection of PSR-11 containers for utility, simplicity, and ease.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "container",
        "psr-11"
    ],
    "authors": [
        {
            "name": "Dhii Team",
            "email": "development@dhii.co"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": false,
    "require": {
        "php": "^7.4 | ^8.0",
        "dhii\/collections-interface": "^0.3.0-alpha4",
        "container-interop\/service-provider": "^0.4"
    },
    "require-dev": {
        "slevomat\/coding-standard": "^6.0",
        "phpunit\/phpunit": "^9.0",
        "vimeo\/psalm": "^5.0",
        "gmazzap\/andrew": "^1.1",
        "psr\/container": "^1.0",
        "psr\/simple-cache": "^1.0",
        "wildwolf\/psr-memory-cache": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Syde\\Vendor\\Zettle\\Dhii\\Container\\": "src\/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Syde\\Vendor\\Zettle\\Dhii\\Container\\UnitTest\\": "tests\/unit",
            "Syde\\Vendor\\Zettle\\Dhii\\Container\\FuncTest\\": "tests\/functional",
            "Syde\\Vendor\\Zettle\\Dhii\\Container\\SysTest\\": "tests\/system",
            "Syde\\Vendor\\Zettle\\Dhii\\Container\\TestHelpers\\": "tests\/helpers"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-develop": "0.1.x-dev"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect\/phpcodesniffer-composer-installer": true
        }
    }
}