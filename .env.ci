# Site — set real values in the ENV_FILE_DATA GitHub Secret
WP_BASE_URL=http://127.0.0.1:8100
WP_USERNAME=admin
WP_PASSWORD=password
STORAGE_STATE_PATH=./storage-states
STORAGE_STATE_PATH_ADMIN=./storage-states/admin.json

# CLI
WPCLI_ENV_TYPE=wpenv

# PayPal POS API
PAYPAL_POS_API_KEY=

# WooCommerce
WC_API_KEY=
WC_API_SECRET=

# Test reporting (optional)
XRAY_CLIENT_ID=
XRAY_CLIENT_SECRET=
XRAY_TEST_EXEC_KEY=
