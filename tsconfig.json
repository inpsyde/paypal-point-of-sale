{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {}
  },
  "include": [
    "playwright.config.ts",
    "global-setup.ts",
    "tests/qa/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "playwright-report", "test-results"]
}
