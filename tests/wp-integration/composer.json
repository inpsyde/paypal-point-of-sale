{
    "name": "inpsyde/paypal-pos-wp-integration-tests",
    "description": "Isolated sub-project that drives the WP Lite Integration Test Helper suite for the PayPal Point of Sale plugin.",
    "license": "GPL-2.0-or-later",
    "type": "project",
    "repositories": [
        {
            "type": "path",
            "url": "../../poc-wp-lite-integration-test-helper/wp-lite-integration-test-helper",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "composer",
            "url": "https://wpackagist.org",
            "only": [
                "wpackagist-plugin/*"
            ]
        },
        {
            "type": "composer",
            "url": "https://repo.packagist.com/inpsyde/"
        },
        {
            "packagist.org": false
        }
    ],
    "require-dev": {
        "phpunit/phpunit": "^10",
        "roots/wordpress-core-installer": "^1.0",
        "roots/wordpress-full": "^6.9",
        "syde/poc-wp-lite-integration-test-helper": "@dev",
        "symfony/var-dumper": "^7.4",
        "vlucas/phpdotenv": "^4.1",
        "wpackagist-plugin/woocommerce": "^10.2"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload-dev": {
        "psr-4": {
            "Syde\\PayPal\\PointOfSale\\Test\\WpIntegration\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/installers": true,
            "roots/wordpress-core-installer": true,
            "johnpbloch/wp-cli-phar": true
        }
    },
    "extra": {
        "wordpress-install-dir": "vendor/wordpress/wordpress",
        "installer-paths": {
            "vendor/wordpress/wordpress/wp-content/plugins/{$name}/": [
                "type:wordpress-plugin"
            ]
        }
    },
    "scripts": {
        "test": "@php ./vendor/bin/phpunit"
    }
}
